msgstr "        $AMCLI [OPCIÓN] [ARGUMENTO]"

#: APP-MANAGER:2166
msgid " Run the \\\"$AMCLI -h\\\" command to find out more"
msgstr " Ejecute el comando \\\"$AMCLI -h\\\" para saber más"

