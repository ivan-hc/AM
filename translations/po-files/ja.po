msgid " You are ready! Start installing your favorite apps locally!"
msgstr " 準備完了です！お気に入りのアプリをローカルにインストールしましょう！"

#: APP-MANAGER:352
msgid " All apps will be installed in $location"
msgstr " すべてのアプリは $location にインストールされます"

#: APP-MANAGER:353
msgid " In case of problems, use the option \\\"-h\\\"."
msgstr " 問題が発生した場合は、オプション \\\"-h\\\" を使用してください。"

#: APP-MANAGER:374
msgid "ERROR: You don't have write access to $APPSPATH"
msgstr "エラー: $APPSPATH への書き込み権限がありません"

#: APP-MANAGER:378
msgid "%b ⚠️ WARNING\\033[0m: \\\"%b%b\\033[0m\\\" is not in PATH, local apps may not run.\\n"
msgstr "%b ⚠️ 警告\\033[0m: \\\"%b%b\\033[0m\\\" が PATH に含まれていないため、ローカルアプリが実行されない可能性があります。\\n"

#: APP-MANAGER:399
msgid "ERROR: No sudo or doas found"
msgstr "エラー: sudo または doas が見つかりません"

#: APP-MANAGER:518
msgid "\\\"$AMCLIUPPER\\\" $AMVERSION: DEVELOPER MODE"
msgstr "\\\"$AMCLIUPPER\\\" $AMVERSION: 開発者モード"

