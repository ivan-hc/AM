msgstr ""
"\\n 上記を修正するには、引数なしで \\\"%b%b reinstall\\033[0m\\\" を実行して"
"ください\\n"

#: APP-MANAGER:1633
msgid "%b\\n Check and update offline lists of additional databases...\\n"
msgstr "%b\\n 追加データベースのオフラインリストを確認・更新中...\\n"

