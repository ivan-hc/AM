msgid "%b\\n Check and update localization...\\n"
msgstr "%b\\n ローカライゼーションを確認・更新中...\\n"

#: APP-MANAGER:1656
msgid "%b\\n Check for updates in modules...\\n"
msgstr "%b\\n モジュールのアップデートを確認中...\\n"

#: APP-MANAGER:1661
msgid " ◆ Downloading $module_name (not previously installed)..."
msgstr " ◆ $module_name をダウンロード中 (以前インストールされていません)..."

#: APP-MANAGER:1670
