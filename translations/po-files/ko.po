msgid " ✔ Clear the contents of $CACHEDIR/am"
msgstr " ✔ $CACHEDIR/am의 내용 지우기"

#: APP-MANAGER:1390 APP-MANAGER:1474
msgid " ✔ Clear the contents of $CACHEDIR/appman"
msgstr " ✔ $CACHEDIR/appman의 내용 지우기"

#: APP-MANAGER:1396
msgid " ✔ Clear the contents of $arg/*.home/.cache"
msgstr " ✔ $arg/*.home/.cache의 내용 지우기"

#: APP-MANAGER:1405
msgid " ✔ Removed $arg/tmp"
msgstr " ✔ $arg/tmp 제거됨"

#: APP-MANAGER:1408
msgid " ✔ Removed $arg/squashfs-root"
msgstr " ✔ $arg/squashfs-root 제거됨"

#: APP-MANAGER:1411
msgid " ✔ Removed $arg/AppDir"
msgstr " ✔ $arg/AppDir 제거됨"

#: APP-MANAGER:1438
msgid " ✖ ERROR: cannot remove \\\"$(basename \"$var\")\\\""
msgstr " ✖ 오류: \\\"$(basename \"$var\")\\\"을(를) 제거할 수 없습니다."

