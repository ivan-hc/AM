msgid " USAGE:\t$AMCLI $1 $2 /path/to/dir"
msgstr " பயன்பாடு:\t$AMCLI $1 $2 /path/to/dir"

#: APP-MANAGER:806 APP-MANAGER:810 APP-MANAGER:820
msgid " ERROR, \\\"$AMDATADIR/newrepo-lists\\\" file not found"
msgstr " பிழை, \\\"$AMDATADIR/newrepo-lists\\\" கோப்பு கிடைக்கவில்லை"

#: APP-MANAGER:807
msgid " New repo ON!"
msgstr " புதிய ரெப்போ ஆன் (ON)!"

#: APP-MANAGER:811
msgid " New repo OFF!"
msgstr " புதிய ரெப்போ ஆஃப் (OFF)!"

#: APP-MANAGER:814
msgid " Source: %b\\n Apps: %b\\n List: %b\\n"
msgstr " மூலம்: %b\\n பயன்பாடுகள்: %b\\n பட்டியல்: %b\\n"

#: APP-MANAGER:817
msgid " Removed all 3rd party repositories"
msgstr " அனைத்து மூன்றாம் தரப்பு களஞ்சியங்களும் அகற்றப்பட்டன"

#: APP-MANAGER:821
msgid "Select a repo from the list or press CTRL+C to abort:\\n%b\\n"
msgstr ""
"பட்டியலிலிருந்து ஒரு ரெப்போவைத் தேர்வு செய்யவும் அல்லது நிறுத்த CTRL+C அழுத்தவும்:"
"\\n%b\\n"

#: APP-MANAGER:824
msgid ">>> Invalid Selection"
msgstr ">>> தவறான தேர்வு"

#: APP-MANAGER:845
msgid " Source: $AMREPO"
msgstr " மூலம்: $AMREPO"

#: APP-MANAGER:916
msgid "Description"
msgstr "விளக்கம்"

#: APP-MANAGER:917
msgid "Source"
msgstr "மூலம்"

#: APP-MANAGER:918
msgid "Related flag"
msgstr "தொடர்புடைய கொடி"

#: APP-MANAGER:919
msgid "Related extension"
msgstr "தொடர்புடைய நீட்டிப்பு"

#: APP-MANAGER:920
msgid "PROGRAM"
msgstr "நிரல்"

#: APP-MANAGER:921
msgid "To get more info about a program"
msgstr "ஒரு நிரல் பற்றி மேலும் அறிய"

#: APP-MANAGER:922
msgid "To install a program near others from other databases"
msgstr "மற்ற தரவுத்தளங்களிலிருந்து மற்றவற்றுக்கு அருகில் ஒரு நிரலை நிறுவ"

#: APP-MANAGER:923
msgid "To install a program only from this third-party database"
msgstr "இந்த மூன்றாம் தரப்பு தரவுத்தளத்திலிருந்து மட்டும் ஒரு நிரலை நிறுவ"

#: APP-MANAGER:924
msgid "To list all programs available in this third-party database"
msgstr "இந்த மூன்றாம் தரப்பு தரவுத்தளத்தில் கிடைக்கும் அனைத்து நிரல்களையும் பட்டியலிட"

