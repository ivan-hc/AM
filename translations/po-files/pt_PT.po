msgid " ERROR: \\\"$AMCLI\\\" cannot manage updates for \\\"$arg\\\""
msgstr " ERRO: \\\"$AMCLI\\\" não pode gerir atualizações para \\\"$arg\\\""

#: APP-MANAGER:2120
