msgid " 💀 ERROR, you can't install applications in \\\"$BINDIR\\\""
msgstr " 💀 HATA, uygulamaları \\\"$BINDIR\\\" içine yükleyemezsiniz"

#: APP-MANAGER:341
msgid ""
" $BINDIR is normally used for executables, Please choose a different path "
"and retry!"
msgstr ""
" $BINDIR genellikle çalıştırılabilir dosyalar için kullanılır, Lütfen farklı "
"bir yol seçin ve tekrar deneyin!"

#: APP-MANAGER:345
msgid " 💀 ERROR: You don't have write access to $location or it is invalid"
msgstr " 💀 HATA: $location konumuna yazma izniniz yok veya konum geçersiz"

