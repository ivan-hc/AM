msgstr " ERRO: \\\"$arg\\\" não está instalado, veja \\\"-f\\\""

#: APP-MANAGER:1887
msgid " ERROR: \\\"$AMCLI\\\" cannot manage updates for \\\"$arg\\\""
msgstr ""
" ERRO: \\\"$AMCLI\\\" não pode gerenciar atualizações para \\\"$arg\\\""

#: APP-MANAGER:1889
msgid " ERROR: \\\"$arg\\\" source is not on Github"
msgstr " ERRO: \\\"$arg\\\" fonte não está no Github"

#: APP-MANAGER:1891
