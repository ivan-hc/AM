msgid " USAGE:\t$AMCLI $1 $2 /path/to/dir"
msgstr " उपयोग:\t$AMCLI $1 $2 /path/to/dir"

#: APP-MANAGER:790 APP-MANAGER:794 APP-MANAGER:804
msgid " ERROR, \\\"$AMDATADIR/newrepo-lists\\\" file not found"
msgstr " त्रुटि, \\\"$AMDATADIR/newrepo-lists\\\" फ़ाइल नहीं मिली"

#: APP-MANAGER:791
msgid " New repo ON!"
msgstr " नई रिपो ON!"

#: APP-MANAGER:795
msgid " New repo OFF!"
msgstr " नई रिपो OFF!"

#: APP-MANAGER:798
msgid " Source: %b\\n Apps: %b\\n List: %b\\n"
msgstr " स्रोत: %b\\n ऐप्स: %b\\n सूची: %b\\n"

#: APP-MANAGER:801
msgid " Removed all 3rd party repositories"
msgstr " सभी तृतीय-पक्ष रिपॉजिटरी हटा दी गईं"

#: APP-MANAGER:805
msgid "Select a repo from the list or press CTRL+C to abort:\\n%b\\n"
msgstr "सूची में से एक रिपो चुनें या छोड़ने के लिए CTRL+C दबाएं:\\n%b\\n"

#: APP-MANAGER:808
msgid ">>> Invalid Selection"
msgstr ">>> अमान्य चयन"

#: APP-MANAGER:829
msgid " Source: $AMREPO"
msgstr " स्रोत: $AMREPO"

#: APP-MANAGER:900
msgid "Description"
msgstr "विवरण"

#: APP-MANAGER:901
msgid "Source"
msgstr "स्रोत"

#: APP-MANAGER:902
msgid "Related flag"
msgstr "संबंधित फ्लैग"

#: APP-MANAGER:903
msgid "Related extension"
msgstr "संबंधित एक्सटेंशन"

#: APP-MANAGER:904
msgid "PROGRAM"
msgstr "प्रोग्राम"

#: APP-MANAGER:905
msgid "To get more info about a program"
msgstr "किसी प्रोग्राम के बारे में अधिक जानकारी प्राप्त करने के लिए"

#: APP-MANAGER:906
msgid "To install a program near others from other databases"
msgstr "अन्य डेटाबेस से अन्य प्रोग्रामों के पास एक प्रोग्राम स्थापित करने के लिए"

#: APP-MANAGER:907
msgid "To install a program only from this third-party database"
msgstr "किसी प्रोग्राम को केवल इस तृतीय-पक्ष डेटाबेस से स्थापित करने के लिए"

#: APP-MANAGER:908
msgid "To list all programs available in this third-party database"
msgstr "इस तृतीय-पक्ष डेटाबेस में उपलब्ध सभी प्रोग्रामों की सूची देखने के लिए"

#: APP-MANAGER:909
msgid "To search for keywords in this third-party database"
msgstr "इस तृतीय-पक्ष डेटाबेस में कीवर्ड खोजने के लिए"

#: APP-MANAGER:1009
msgid ""
"Zsh completion requires editing the main configuration file, but it may cause problems.\\nSee "
"https://github.com/ivan-hc/AM/issues/1843\\n"
msgstr ""
"Zsh पूर्णता के लिए मुख्य कॉन्फ़िगरेशन फ़ाइल को संपादित करने की आवश्यकता होती है, लेकिन इससे समस्याएं हो सकती हैं।"
"\\nदेखें https://github.com/ivan-hc/AM/issues/1843\\n"

#: APP-MANAGER:1010
msgid "Want to proceed anyway? (y,N)"
msgstr "क्या आप किसी भी तरह आगे बढ़ना चाहते हैं? (y,N)"

#: APP-MANAGER:1023
msgid "Shell completion has been enabled!"
msgstr "शेल पूर्णता सक्षम कर दी गई है!"

#: APP-MANAGER:1222
msgid "Validation successful!"
msgstr "सत्यापन सफल!"

#: APP-MANAGER:1225
msgid "ERROR: Invalid token or insufficient permissions!"
msgstr "त्रुटि: अमान्य टोकन या अपर्याप्त अनुमतियाँ!"

#: APP-MANAGER:1228
msgid "ERROR: Unexpected response (HTTP $HTTP_STATUS)"
msgstr "त्रुटि: अप्रत्याशित प्रतिक्रिया (HTTP $HTTP_STATUS)"

#: APP-MANAGER:1236
msgid " ✖ No file named $ghapikey_file has been found"
msgstr " ✖ $ghapikey_file नाम की कोई फ़ाइल नहीं मिली"

#: APP-MANAGER:1247
msgid " ✔ $ghapikey_file has been removed"
msgstr " ✔ $ghapikey_file हटा दिया गया है"

#: APP-MANAGER:1248
msgid " ✔ Authorization headers removed from updater files"
msgstr " ✔ अपडेटर फ़ाइलों से अधिकृति हेडर हटा दिए गए हैं"

#: APP-MANAGER:1258
msgid "ERROR: Wrong expression, validation failed!"
msgstr "त्रुटि: गलत अभिव्यक्ति, सत्यापन विफल!"

#: APP-MANAGER:1269
msgid " ⚠️ Warning: Stored GitHub API token is invalid or expired"
msgstr " ⚠️ चेतावनी: संग्रहीत GitHub API टोकन अमान्य या समाप्त हो गया है"

#: APP-MANAGER:1271
msgid " Please either:"
msgstr " कृपया या तो:"

#: APP-MANAGER:1272
msgid "   1. Generate a new token and add it with: $AMCLI apikey YOUR_NEW_TOKEN"
msgstr "   1. एक नया टोकन उत्पन्न करें और इसे जोड़ें: $AMCLI apikey YOUR_NEW_TOKEN"

#: APP-MANAGER:1273
msgid "   2. Remove the invalid token with: $AMCLI apikey del"
msgstr "   2. अमान्य टोकन को हटा दें: $AMCLI apikey del"

#: APP-MANAGER:1275
msgid " For instructions on creating GitHub tokens, see:"
msgstr " GitHub टोकन बनाने के निर्देशों के लिए, देखें:"

#: APP-MANAGER:1303
msgid ""
"$DIVIDING_LINE\\n \\\"AM\\\" is running as \\\"AppMan\\\", use ${Green}am --system\\033[0m to "
"switch it back to \\\"AM\\\"\\n$DIVIDING_LINE\\n"
msgstr ""
"$DIVIDING_LINE\\n \\\"AM\\\" \\\"AppMan\\\" के रूप में चल रहा है, इसे वापस \\\"AM\\\" में बदलने के लिए $"
"{Green}am --system\\033[0m का उपयोग करें\\n$DIVIDING_LINE\\n"

#: APP-MANAGER:1304
msgid "$DIVIDING_LINE\\n \\\"AppMan Mode\\\" disabled! \\n$DIVIDING_LINE\\n"
msgstr "$DIVIDING_LINE\\n \\\"AppMan Mode\\\" अक्षम! \\n$DIVIDING_LINE\\n"

#: APP-MANAGER:1305
msgid ""
"$DIVIDING_LINE\\nNOTE: You can also choose to simply use \\\"--user\\\" as a flag to install "
"apps locally (options \\\"-i\\\", \\\"-ia\\\" and \\\"-e\\\") instead of going fully into \\"
"\"AppMan Mode\\\". \\\"AM\\\" can  handle local applications as well.\\n$DIVIDING_LINE\\n"
msgstr ""
"$DIVIDING_LINE\\nनोट: आप पूरी तरह से \\\"AppMan Mode\\\" में जाने के बजाय, ऐप्स को स्थानीय रूप से स्थापित "
"करने के लिए बस एक फ्लैग के रूप में \\\"--user\\\" का उपयोग करने का भी विकल्प चुन सकते हैं (विकल्प \\\"-i\\\", "
"\\\"-ia\\\" और \\\"-e\\\"). \\\"AM\\\" स्थानीय अनुप्रयोगों को भी संभाल सकता है।\\n$DIVIDING_LINE\\n"

#: APP-MANAGER:1309
msgid " This function only works for AM"
msgstr " यह फ़ंक्शन केवल AM के लिए काम करता है"

#: APP-MANAGER:1311
msgid " Do you wish to enter \\\"AppMan Mode\\\" (y,N)?"
