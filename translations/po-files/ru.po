#: APP-MANAGER:118 APP-MANAGER:697
msgid ""
" ${RED}💀 ERROR! MISSING ESSENTIAL COMMANDS\\033[0m: %s\\n\\n Install the "
"above and try again! \\n"
msgstr ""
" ${RED}💀 ОШИБКА! ОТСУТСТВУЮТ НЕОБХОДИМЫЕ КОМАНДЫ\\033[0m: %s\\n\\n "
"Установите указанное выше и попробуйте снова! \\n"

#: APP-MANAGER:214
msgid "Add a suitable locale code, for example \\\"it\\\" for Italian\\n\\n"
msgstr ""
"Добавьте подходящий код локали, например \\\"it\\\" для итальянского\\n\\n"

