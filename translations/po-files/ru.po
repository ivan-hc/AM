msgstr "\\n  Замена используемой версии \\\"%b\\\" ЗАВЕРШЕНА! \\n"

#: APP-MANAGER:1706
msgid "\\n See https://github.com/ivan-hc/AM/commits/main\\n\\n"
msgstr "\\n См. https://github.com/ivan-hc/AM/commits/main\\n\\n"

#: APP-MANAGER:1708
msgid ""
" ◆ \\\"$AMCLIUPPER\\\" IS ALREADY UPDATED, CURRENT VERSION \\"
"\"$CURRENT_AM_VERSION\\\""
