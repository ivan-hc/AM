msgid ""
"\\n Please do not use \\\"sudo\\\" to execute \\\"%b\\\", try again.\\n\\n"
msgstr ""
"\\n Пожалуйста, не используйте \\\"sudo\\\" для запуска \\\"%b\\\", "
"попробуйте снова.\\n\\n"

